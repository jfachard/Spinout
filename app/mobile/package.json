{
  "name": "@spinout/mobile",
  "version": "1.0.0",
  "main": "expo-router/entry",
  "scripts": {
    "android": "node --require ./tailwind-resolve.cjs ../../node_modules/expo/bin/cli start --android",
    "ios": "node --require ./tailwind-resolve.cjs ../../node_modules/expo/bin/cli start --ios",
    "start": "node --require ./tailwind-resolve.cjs ../../node_modules/expo/bin/cli start",
    "start:tunnel": "node --require ./tailwind-resolve.cjs ../../node_modules/expo/bin/cli start --tunnel --clear",
    "prebuild": "node --require ./tailwind-resolve.cjs ../../node_modules/expo/bin/cli prebuild",
    "lint": "eslint \"**/*.{js,jsx,ts,tsx}\" && prettier -c \"**/*.{js,jsx,ts,tsx,json}\"",
    "format": "eslint \"**/*.{js,jsx,ts,tsx}\" --fix && prettier \"**/*.{js,jsx,ts,tsx,json}\" --write",
    "web": "node --require ./tailwind-resolve.cjs ../../node_modules/expo/bin/cli start --web"
  },
  "dependencies": {
    "@expo-google-fonts/baloo-2": "^0.4.2",
    "@expo-google-fonts/nunito": "^0.4.2",
    "@expo/vector-icons": "^15.0.2",
    "@hookform/resolvers": "^5.4.0",
    "@react-navigation/native": "^7.1.6",
    "@spinout/shared": "file:../../packages/shared",
    "clsx": "^2.1.1",
    "expo": "^54.0.0",
    "expo-camera": "~17.0.10",
    "expo-constants": "~18.0.9",
    "expo-font": "^14.0.12",
    "expo-linking": "~8.0.8",
    "expo-router": "~6.0.10",
    "expo-secure-store": "^56.0.4",
    "expo-status-bar": "~3.0.8",
    "expo-system-ui": "~6.0.7",
    "expo-web-browser": "~15.0.7",
    "lucide-react-native": "^1.21.0",
    "nativewind": "latest",
    "react": "19.1.0",
    "react-dom": "19.1.0",
    "react-hook-form": "^7.79.0",
    "react-native": "0.81.5",
    "react-native-css-interop": "^0.2.5",
    "react-native-gesture-handler": "~2.28.0",
    "react-native-reanimated": "~4.1.1",
    "react-native-safe-area-context": "~5.6.0",
    "react-native-screens": "~4.16.0",
    "react-native-svg": "^15.15.5",
    "react-native-web": "^0.21.0",
    "react-native-worklets": "0.5.1",
    "tailwind-merge": "^3.6.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@babel/core": "^7.20.0",
    "@types/react": "~19.1.10",
    "babel-preset-expo": "~54.0.11",
    "eslint": "^9.25.1",
    "eslint-config-expo": "~10.0.0",
    "eslint-config-prettier": "^10.1.2",
    "prettier": "^3.2.5",
    "prettier-plugin-tailwindcss": "^0.5.11",
    "tailwindcss": "^3.4.0",
    "typescript": "~5.9.2"
  },
  "private": true
}
